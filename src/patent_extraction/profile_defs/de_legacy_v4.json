{
  "name": "de_legacy_v4",
  "description": "German legacy patent extraction profile using the V4 prompt, vLLM, and two-pass targeted reruns.",
  "prompt_resource": "de_legacy_v4.txt",
  "extraction": {
    "model_name": "mistralai/Mistral-Small-3.1-24B-Instruct-2503",
    "backend": "vllm",
    "guardrail_profile": "de_legacy_self_applicant",
    "max_ocr_chars": 10000,
    "max_new_tokens": 1024,
    "temperature": 0.0,
    "do_sample": false,
    "save_strategy_meta": false,
    "save_raw_output": false,
    "timings": "basic"
  },
  "vllm": {
    "enable_prefix_caching": true,
    "tensor_parallel_size": 1,
    "gpu_memory_utilization": 0.9,
    "max_model_len": 16384,
    "swap_space": 4.0,
    "enforce_eager": false,
    "doc_batch_size": 32,
    "sort_by_prompt_length": true,
    "tokenizer_mode": "auto"
  },
  "strategy": {
    "name": "two_pass_targeted",
    "extraction_mode": "auto",
    "chunk_size_chars": 7000,
    "chunk_overlap_chars": 800,
    "extraction_passes": 2,
    "header_lines": 30,
    "targeted_rerun_threshold": 0.6,
    "self_consistency_n": 2,
    "self_consistency_temp": 0.2,
    "merge_policy": "prefer_non_null"
  }
}
