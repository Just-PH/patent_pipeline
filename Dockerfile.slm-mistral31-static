FROM nvidia/cuda:12.1.1-cudnn8-runtime-ubuntu22.04

ARG TORCH_VERSION=2.5.1
ARG TORCH_CUDA_TAG=cu121
ARG HF_MODEL=mistralai/Mistral-Small-3.1-24B-Instruct-2503

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app/src \
    HF_HOME=/data/cache/huggingface \
    HF_HUB_CACHE=/data/cache/huggingface \
    TORCH_HOME=/data/cache/torch \
    HF_MODEL=${HF_MODEL} \
    TOKENIZERS_PARALLELISM=false \
    CC=/usr/bin/gcc \
    CXX=/usr/bin/g++

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    build-essential \
    ca-certificates \
    curl \
    git \
    libgomp1 \
    python3 \
    python3-dev \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

RUN ln -sf /usr/bin/python3 /usr/bin/python && \
    ln -sf /usr/bin/pip3 /usr/bin/pip

RUN mkdir -p /data/cache/huggingface /data/cache/torch

RUN python -m pip install --no-cache-dir -U pip setuptools wheel

RUN python -m pip install --no-cache-dir \
    "torch==${TORCH_VERSION}+${TORCH_CUDA_TAG}" \
    "torchaudio==${TORCH_VERSION}+${TORCH_CUDA_TAG}" \
    --index-url "https://download.pytorch.org/whl/${TORCH_CUDA_TAG}"

COPY requirements.slm-mistral31.txt /tmp/requirements.slm-mistral31.txt
RUN python -m pip install --no-cache-dir -r /tmp/requirements.slm-mistral31.txt && \
    rm -f /tmp/requirements.slm-mistral31.txt

COPY src /app/src
COPY scripts /app/scripts

RUN python - <<'PY'
import importlib.util
import shutil
import torch
import transformers
from transformers import BitsAndBytesConfig

try:
    from transformers import Mistral3ForCausalLM
except Exception:
    Mistral3ForCausalLM = None

try:
    from transformers import Mistral3ForConditionalGeneration
except Exception:
    Mistral3ForConditionalGeneration = None

if Mistral3ForCausalLM is None and Mistral3ForConditionalGeneration is None:
    raise RuntimeError(
        "This transformers build exposes neither Mistral3ForCausalLM nor "
        "Mistral3ForConditionalGeneration."
    )

print("torch:", torch.__version__)
print("transformers:", transformers.__version__)
print("bitsandbytes_installed:", importlib.util.find_spec("bitsandbytes") is not None)
print("cuda_available_during_build:", torch.cuda.is_available())
print("mistral3_causal_available:", Mistral3ForCausalLM is not None)
print("mistral3_conditional_available:", Mistral3ForConditionalGeneration is not None)
print("bitsandbytes_config_ok:", BitsAndBytesConfig.__name__)
print("cc:", shutil.which("cc"))
print("gcc:", shutil.which("gcc"))
print("clang:", shutil.which("clang"))
PY

# Compiler-enabled variant intended for cache_implementation=static benchmarks
# and production use after validation on the target GPU stack.
CMD ["bash"]
